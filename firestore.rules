rules_version = '2';

// "Admin" in this project == any signed-in Firebase Auth user. admin.html only
// ever calls signInWithEmailAndPassword (no public sign-up, no custom claims/
// roles collection anywhere in the codebase) - accounts can only be created via
// the Firebase Console / Admin SDK, so request.auth != null is a safe proxy for
// "is an admin" today. If self-serve sign-up is ever added, this needs revisiting
// (e.g. a custom claim or an allowlist doc) - out of scope for now.
service cloud.firestore {
  match /databases/{database}/documents {

    // Hero/site content (App.tsx reads this unauthenticated on every page load).
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy Firestore-authored products (admin.html "Додати новий товар").
    // The storefront no longer reads this (App.tsx now sources the catalog
    // from KeyCRM) - only admin.html's create/edit form still touches it - so
    // read is admin-only too, unlike the collections below.
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }

    // Point discounts keyed by KeyCRM product id (admin.html "Точкова знижка").
    // services/promotions.ts reads active promotions unauthenticated on the
    // storefront, so read must stay public; only admin.html writes.
    match /promotions/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin-uploaded extra photos overlaid on the KeyCRM catalog, keyed by
    // KeyCRM product id (admin.html product modal). Not read by the storefront
    // yet, but public read is opened now so the planned App.tsx merge doesn't
    // need another rules deploy later - it's just photo URLs, nothing sensitive.
    match /productMedia/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else stays locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
